<manifest version="1.0" type="device" >
    <hal format="hidl">
        <name>android.hardware.automotive.can</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>ICanController</name>
            <instance>socketcan</instance>
        </interface>
        <interface>
            <name>ICanBus</name>
            <instance>can0</instance>
            <instance>can1</instance>
        </interface>
        <interface>
            <name>ICanBusIsotp</name>
            <instance>can0</instance>
            <instance>can1</instance>
        </interface>
    </hal>
</manifest>
